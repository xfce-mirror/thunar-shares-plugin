#: libshares/libshares-util.c:166
msgid "Please, write a name."
msgstr "ກະລຸນາຂຽນຊື່."

#. Warn the user
#: libshares/libshares-util.c:174
msgid ""
"Share name too long. Some old clients may have problems to access it, "
"continue anyway?"
msgstr "ຊື່ການແບ່ງປັນຍາວເກີນໄປ. ບາງລູກຂ່າຍລຸ້ນເກົ່າອາດມີບັນຫາໃນການເຂົ້າເຖິງ, ຍັງຕ້ອງການສືບຕໍ່ບໍ່?"

#: libshares/libshares-util.c:187
#, c-format
msgid "Error while getting share information: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ກຳລັງດຶງຂໍ້ມູນການແບ່ງປັນ: %s"

#: libshares/libshares-util.c:197
msgid "Another share has the same name"
msgstr "ມີການແບ່ງປັນອື່ນທີ່ໃຊ້ຊື່ນີ້ແລ້ວ"

#: libshares/libshares-util.c:251
msgid "Cannot modify the share:"
msgstr "ບໍ່ສາມາດແກ້ໄຂການແບ່ງປັນໄດ້:"

#: libshares/libshares-util.c:353
msgid ""
"Thunar needs to add some permissions to your folder in order to share it. Do"
" you agree?"
msgstr "Thunar ຈຳເປັນຕ້ອງເພີ່ມການອະນຸຍາດບາງຢ່າງໃຫ້ກັບໂຟນເດີຂອງທ່ານເພື່ອແບ່ງປັນມັນ. ທ່ານຕົກລົງບໍ່?"

#: libshares/libshares-util.c:392
msgid "Error when changing folder permissions."
msgstr "ເກີດຂໍ້ຜິດພາດໃນຂະນະທີ່ປ່ຽນການອະນຸຍາດໂຟນເດີ."

#: libshares/shares.c:165
#, c-format
msgid "%s %s %s returned with signal %d"
msgstr "%s %s %s ສົ່ງຄືນດ້ວຍສັນຍານ %d"

#: libshares/shares.c:174
#, c-format
msgid "%s %s %s failed for an unknown reason"
msgstr "%s %s %s ຫຼົ້ມເຫຼວຍ້ອນເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#: libshares/shares.c:195
#, c-format
msgid "'net usershare' returned error %d: %s"
msgstr "'net usershare' ສົ່ງຄືນຂໍ້ຜິດພາດ %d: %s"

#: libshares/shares.c:197
#, c-format
msgid "'net usershare' returned error %d"
msgstr "'net usershare' ສົ່ງຄືນຂໍ້ຜິດພາດ %d"

#: libshares/shares.c:231
msgid "the output of 'net usershare' is not in valid UTF-8 encoding"
msgstr "ຜົນການສະແດງຂອງ 'net usershare' ບໍ່ໄດ້ຢູ່ໃນຮູບແບບລະຫັດ UTF-8 ທີ່ຖືກຕ້ອງ"

#: libshares/shares.c:490 libshares/shares.c:702
msgid "Failed"
msgstr "ຫຼົ້ມເຫຼວ"

#: libshares/shares.c:592
#, c-format
msgid "Samba's testparm returned with signal %d"
msgstr "Samba's testparm ສົ່ງຄືນດ້ວຍສັນຍານ %d"

#: libshares/shares.c:598
msgid "Samba's testparm failed for an unknown reason"
msgstr "Samba's testparm ຫຼົ້ມເຫຼວຍ້ອນເຫດຜົນທີ່ບໍ່ຮູ້ຈັກ"

#: libshares/shares.c:613
#, c-format
msgid "Samba's testparm returned error %d: %s"
msgstr "Samba's testparm ສົ່ງຄືນຂໍ້ຜິດພາດ %d: %s"

#: libshares/shares.c:615
#, c-format
msgid "Samba's testparm returned error %d"
msgstr "Samba's testparm ສົ່ງຄືນຂໍ້ຜິດພາດ %d"

#: libshares/shares.c:784
#, c-format
msgid "Cannot remove the share for path %s: that path is not shared"
msgstr "ບໍ່ສາມາດລຶບການແບ່ງປັນສຳລັບເສັ້ນທາງ %s: ເສັ້ນທາງນັ້ນບໍ່ໄດ້ຖືກແບ່ງປັນ"

#: libshares/shares.c:837
msgid ""
"Cannot change the path of an existing share; please remove the old share "
"first and add a new one"
msgstr "ບໍ່ສາມາດປ່ຽນເສັ້ນທາງຂອງການແບ່ງປັນທີ່ມີຢູ່; ກະລຸນາລຶບການແບ່ງປັນເກົ່າອອກກ່ອນ ແລ້ວຈຶ່ງເພີ່ມໃໝ່"

#: thunar-plugin/tsp-page.c:150
msgid "<b>Folder Sharing</b>"
msgstr "<b>ການແບ່ງປັນໂຟນເດີ</b>"

#. Share check button
#: thunar-plugin/tsp-page.c:160 thunar-plugin/tsp-provider.c:170
msgid "Share this folder"
msgstr "ແບ່ງປັນໂຟນເດີນີ້"

#. Share name
#: thunar-plugin/tsp-page.c:171
msgid "Share Name:"
msgstr "ຊື່ການແບ່ງປັນ:"

#. Share comments
#: thunar-plugin/tsp-page.c:181
msgid "Comments:"
msgstr "ຄຳອະທິບາຍ:"

#. Write access
#: thunar-plugin/tsp-page.c:190
msgid "Allow others users to write in this folder"
msgstr "ອະນຸຍາດໃຫ້ຜູ້ໃຊ້ອື່ນຂຽນລົງໃນໂຟນເດີນີ້"

#. Guest access
#: thunar-plugin/tsp-page.c:196
msgid "Allow Guest access"
msgstr "ອະນຸຍາດໃຫ້ຜູ້ຢ້ຽມຊົມເຂົ້າເຖິງ"

#. Apply button
#: thunar-plugin/tsp-page.c:201
msgid "_Apply"
msgstr "ນຳໃຊ້"

#: thunar-plugin/tsp-page.c:292
msgid "Share"
msgstr "ແບ່ງປັນ"

#: thunar-plugin/tsp-page.c:364
msgid "You are not the owner of the folder."
msgstr "ທ່ານບໍ່ແມ່ນເຈົ້າຂອງໂຟນເດີນີ້."

#: thunar-plugin/tsp-page.c:372
msgid ""
"You may need to install Samba, check your user permissions (usershares group) and re-login.\n"
"<b>More info:</b> <u>https://docs.xfce.org/xfce/thunar/thunar-shares-plugin</u>"
msgstr "ທ່ານອາດຈະຕ້ອງຕິດຕັ້ງ Samba, ກວດສອບການອະນຸຍາດຜູ້ໃຊ້ຂອງທ່ານ (ກຸ່ມ usershares) ແລະ ເຂົ້າສູ່ລະບົບຄືນໃໝ່.\n<b>ຂໍ້ມູນເພີ່ມເຕີມ:</b> <u>https://docs.xfce.org/xfce/thunar/thunar-shares-plugin</u>"

#: thunar-plugin/tsp-provider.c:169
msgid "Folder _Sharing"
msgstr "ການ_ແບ່ງປັນໂຟນເດີ"
